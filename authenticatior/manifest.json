{
  "manifest_version": 3,
  "name": "Authenticator Pro",
  "version": "1.3.0",
  "description": "Secure 2FA manager with AES encryption, Master Password, and professional UI.",
  "permissions": ["storage", "session"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
